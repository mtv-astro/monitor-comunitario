APP_ENV=production
APP_TIMEZONE=America/Sao_Paulo

# Supabase/Postgres connection string.
# Example:
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@<host>:6543/postgres?sslmode=require
ADMIN_API_KEY=<strong-admin-api-key>

CELESC_OUTAGES_URL=https://www.celesc.com.br/avisos-de-desligamentos
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=30000
SNAPSHOT_DIR=/app/snapshots

SCHEDULER_ENABLED=true
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=0

NOTIFICATION_PROVIDER=app

EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_ENABLED=false

ADS_ENABLED=false
ADS_PROVIDER=placeholder
ADSENSE_CLIENT_ID=
ADSENSE_DEFAULT_SLOT=

ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=none
GOOGLE_ANALYTICS_ID=

CONSENT_REQUIRED=true
CONSENT_VERSION=2026-06-16-v1
